{
  "name": "ai-research-assistant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "db:init": "node src/lib/database/init.js",
    "review": "npm run typecheck && npm run lint && npm run build",
    "review:quick": "npm run typecheck && npm run lint",
    "security:audit": "npm audit --audit=moderate",
    "security:fix": "npm audit fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@onlyoffice/document-editor-react": "^1.4.1",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build6",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.6.0",
    "clsx": "^2.0.0",
    "docx": "^9.6.0",
    "mathjs": "^15.1.1",
    "next": "15.5.12",
    "openai": "^4.0.0",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "sql.js": "^1.10.3",
    "tailwind-merge": "^2.0.0",
    "tesseract.js": "^5.1.1",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.8",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.5.12",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
