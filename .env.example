# AI Model API Keys
# Replace with your actual API keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GLM_API_KEY=your_glm_api_key_here
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-google-api-key
GROQ_API_KEY=gsk-your-groq-key
MISTRAL_API_KEY=your-mistral-key

# Web Search (Ollama Cloud - FREE)
# Get your free API key at https://ollama.com/settings/keys
OLLAMA_API_KEY=your-ollama-api-key-here

# Search API Keys (Alternative providers)
TAVILY_API_KEY=your_tavily_api_key_here
BRAVE_API_KEY=your_brave_api_key_here

# Ollama Configuration
OLLAMA_API_URL=http://localhost:11434/api

# Database
DATABASE_PATH=./data/assistant.db

# Application
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ONLYOFFICE Document Server
NEXT_PUBLIC_ONLYOFFICE_URL=http://localhost:8080
# Use host.docker.internal for Docker Desktop (Mac/Windows), or your real domain in production
NEXT_PUBLIC_DASHBOARD_URL=http://host.docker.internal:3000
# JWT secret MUST match the Docker container's JWT_SECRET
ONLYOFFICE_JWT_SECRET=your-super-secret-32-char-key-here
JWT_ENABLED=true

# Authentication (optional - disabled by default)
# Set to 'true' to enable authentication for production/multi-user deployments
ENABLE_AUTH=false
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_USER_PASSWORD=user123
